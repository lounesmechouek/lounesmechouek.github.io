<footer class="w-full py-16 mt-32 border-t border-slate-200 bg-slate-50">
  <div class="flex flex-col md:flex-row justify-between items-center max-w-7xl mx-auto px-8">
    <div class="font-body text-sm tracking-wide uppercase font-semibold text-slate-600 mb-8 md:mb-0">
      &copy; {{ site.copyright }} {{ site.name }}. {{ site.footerText }}
    </div>
    <div class="flex gap-12 font-body text-sm tracking-wide uppercase font-semibold">
      <a class="text-slate-500 hover:text-indigo-600 transition-colors" href="{{ site.links.github }}" target="_blank" rel="noopener">GitHub</a>
      <a class="text-slate-500 hover:text-indigo-600 transition-colors" href="{{ site.links.linkedin }}" target="_blank" rel="noopener">LinkedIn</a>
      <a class="text-slate-500 hover:text-indigo-600 transition-colors" href="{{ site.links.medium }}" target="_blank" rel="noopener">Medium</a>
      <a class="text-slate-500 hover:text-indigo-600 transition-colors" href="/contact/">Contact</a>
    </div>
  </div>
</footer>
