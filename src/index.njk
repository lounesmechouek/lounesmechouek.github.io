---
layout: base.njk
activePage: home
---

<!-- Hero Section -->
<section class="max-w-7xl mx-auto px-8 pt-32 pb-24 md:pt-48 md:pb-40">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
    <div class="lg:col-span-8">
      <h1 class="font-headline text-[3.5rem] leading-[1.1] tracking-tight mb-8">
        {{ site.tagline | safe }}
      </h1>
      <p class="text-on-surface-variant font-body text-xl max-w-2xl leading-relaxed mb-12">
        {{ site.description }}
      </p>
      <div class="flex flex-wrap gap-6">
        <a class="bg-primary text-on-primary px-8 py-4 rounded-md font-medium hover:opacity-90 transition-opacity flex items-center gap-2" href="/projects/">
          Explore Projects
          <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </a>
        <a class="bg-surface-container-high text-on-surface px-8 py-4 rounded-md font-medium hover:bg-surface-container-highest transition-colors" href="/writing/">
          Read Technical Blog
        </a>
      </div>
    </div>
    <div class="lg:col-span-4 hidden lg:block">
      <div class="aspect-square bg-surface-container-low overflow-hidden rounded-lg">
        <img class="w-full h-full object-cover grayscale opacity-80" src="{{ site.heroImage }}" alt="Abstract editorial image"/>
      </div>
    </div>
  </div>
</section>

<!-- Featured Projects -->
<section class="bg-surface-container-low py-32" id="projects">
  <div class="max-w-7xl mx-auto px-8">
    <div class="flex justify-between items-end mb-16">
      <div>
        <span class="font-label text-xs font-semibold tracking-widest uppercase text-outline mb-4 block">Selected Works</span>
        <h2 class="font-headline text-4xl text-on-surface">Engineering Projects</h2>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
      {% for project in projects %}
        {% if project.featured %}
          {% if project.layout == "wide" %}
          <div class="md:col-span-7 bg-surface p-12 rounded-xl group hover:bg-surface-container-lowest transition-colors duration-500">
            <div class="flex justify-between items-start mb-8">
              <span class="text-[0.75rem] font-semibold uppercase tracking-widest text-secondary">{{ project.category }}</span>
              <span class="text-[0.75rem] font-semibold text-outline">{{ project.status }}</span>
            </div>
            <h3 class="font-headline text-3xl mb-4 text-on-surface">{{ project.title }}</h3>
            <p class="text-on-surface-variant text-lg max-w-md leading-relaxed mb-8">{{ project.summary }}</p>
            <div class="w-full h-64 bg-surface-container-low rounded-lg overflow-hidden">
              <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" src="{{ project.coverImage }}" alt="{{ project.title }}"/>
            </div>
          </div>
          {% elif project.layout == "narrow" %}
          <div class="md:col-span-5 bg-surface p-12 rounded-xl group hover:bg-surface-container-lowest transition-colors duration-500 flex flex-col justify-between">
            <div>
              <div class="flex justify-between items-start mb-8">
                <span class="text-[0.75rem] font-semibold uppercase tracking-widest text-secondary">{{ project.category }}</span>
                <span class="text-[0.75rem] font-semibold text-outline">{{ project.status }}</span>
              </div>
              <h3 class="font-headline text-3xl mb-4 text-on-surface">{{ project.title }}</h3>
              <p class="text-on-surface-variant text-lg leading-relaxed mb-8">{{ project.summary }}</p>
            </div>
            <div class="h-48 bg-surface-container-low rounded-lg overflow-hidden">
              <img class="w-full h-full object-cover grayscale brightness-90" src="{{ project.coverImage }}" alt="{{ project.title }}"/>
            </div>
          </div>
          {% elif project.layout == "full" %}
          <div class="md:col-span-12 bg-surface p-12 rounded-xl group hover:bg-surface-container-lowest transition-colors duration-500 flex flex-col md:flex-row gap-12 items-center">
            <div class="flex-1">
              <div class="flex justify-between items-start mb-8">
                <span class="text-[0.75rem] font-semibold uppercase tracking-widest text-secondary">{{ project.category }}</span>
                <span class="text-[0.75rem] font-semibold text-outline">{{ project.status }}</span>
              </div>
              <h3 class="font-headline text-4xl mb-4 text-on-surface">{{ project.title }}</h3>
              <p class="text-on-surface-variant text-xl max-w-xl leading-relaxed mb-8">{{ project.summary }}</p>
              <a class="inline-flex items-center gap-2 font-medium text-secondary hover:gap-4 transition-all" href="/projects/">
                View Case Study <span class="material-symbols-outlined">east</span>
              </a>
            </div>
            <div class="w-full md:w-1/3 aspect-video bg-surface-container-low rounded-lg overflow-hidden">
              <img class="w-full h-full object-cover opacity-90" src="{{ project.coverImage }}" alt="{{ project.title }}"/>
            </div>
          </div>
          {% endif %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<!-- Focus Areas -->
<section class="py-32 bg-surface">
  <div class="max-w-7xl mx-auto px-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-24">
      <div>
        <h2 class="font-headline text-4xl text-on-surface mb-6 leading-tight">Primary Focus Areas</h2>
        <p class="text-on-surface-variant text-lg leading-relaxed">Systematic inquiry into the underlying mechanics of intelligent systems.</p>
      </div>
      <div class="lg:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-16">
        {% for area in site.focusAreas %}
        <div>
          <span class="text-primary text-3xl font-headline italic mb-4 block">{{ area.number }}</span>
          <h4 class="font-label text-sm font-semibold tracking-widest uppercase mb-4">{{ area.title }}</h4>
          <p class="text-on-surface-variant">{{ area.description }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<!-- Latest Writing -->
<section class="py-32 bg-surface-container-low" id="writing">
  <div class="max-w-7xl mx-auto px-8">
    <div class="mb-20">
      <span class="font-label text-xs font-semibold tracking-widest uppercase text-outline mb-4 block">The Journal</span>
      <h2 class="font-headline text-4xl text-on-surface">Recent Field Notes</h2>
    </div>
    <div class="space-y-12">
      {% set latestPosts = collections.posts | limit(4) %}
      {% for post in latestPosts %}
      <article class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center {{ 'border-b border-outline-variant/20 pb-12' if not loop.last }} group cursor-pointer">
        <div class="lg:col-span-2 font-label text-xs font-semibold text-outline uppercase tracking-widest">
          {{ post.date | dateFormat("short") }}
        </div>
        <div class="lg:col-span-7">
          <a href="{{ post.url }}" class="block">
            <h3 class="font-headline text-2xl group-hover:text-secondary transition-colors">{{ post.data.title }}</h3>
            <p class="mt-2 text-on-surface-variant">{{ post.data.excerpt }}</p>
          </a>
        </div>
        <div class="lg:col-span-3 text-right hidden lg:block">
          <span class="font-label text-xs font-semibold px-3 py-1 bg-surface rounded-full border border-outline-variant/20">{{ post.data.category }}</span>
        </div>
      </article>
      {% endfor %}

      {% if not latestPosts.length %}
      <p class="text-on-surface-variant italic">No articles published yet. Add markdown files to <code>src/writing/</code> to get started.</p>
      {% endif %}
    </div>
  </div>
</section>

<!-- Experience Snapshot -->
<section class="py-32 bg-surface">
  <div class="max-w-7xl mx-auto px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
      <div class="lg:col-span-4">
        <h2 class="font-headline text-4xl text-on-surface mb-8">Professional <br/>Trajectory</h2>
        <div class="w-12 h-0.5 bg-secondary mb-8"></div>
        <p class="text-on-surface-variant text-lg leading-relaxed">Bridging the gap between theoretical computer science and industrial engineering.</p>
      </div>
      <div class="lg:col-span-8 space-y-4">
        {% for role in experience %}
        <div class="p-10 {{ 'bg-surface-container-lowest rounded-xl' if role.style == 'highlighted' else 'bg-surface rounded-xl' }}">
          <div class="flex justify-between items-center mb-4">
            <h3 class="font-headline text-2xl">{{ role.role }}</h3>
            <span class="font-label text-xs font-semibold text-outline">{{ role.period | upper }}</span>
          </div>
          <div class="text-primary font-medium mb-4">{{ role.company }}</div>
          <p class="text-on-surface-variant">{{ role.ownership }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
