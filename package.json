{
  "name": "portfolio",
  "version": "1.0.0",
  "scripts": {
    "build:css": "npx tailwindcss -i ./src/assets/css/input.css -o ./_site/assets/css/style.css --minify",
    "watch:css": "npx tailwindcss -i ./src/assets/css/input.css -o ./_site/assets/css/style.css --watch",
    "build:11ty": "npx @11ty/eleventy",
    "watch:11ty": "npx @11ty/eleventy --serve --port=8080",
    "build": "npm run build:11ty && npm run build:css",
    "dev": "concurrently \"npm run watch:11ty\" \"npm run watch:css\""
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "tailwindcss": "^3.4.0",
    "concurrently": "^8.2.0",
    "markdown-it": "^14.0.0",
    "markdown-it-anchor": "^9.0.0"
  }
}
